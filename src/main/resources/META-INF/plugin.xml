<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- Unique identifier of the plugin. It should be FQN. It cannot be changed between the plugin versions. -->
    <id>com.babs.crudwizardrygenerator</id>

    <!-- Public plugin name should be written in Title Case.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-name -->
    <name>Crudwizardrygenerator</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <vendor url="https://www.babscrontekker.com">BabsCron</vendor>

    <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-description -->
    <description><![CDATA[
    Enter short description for your plugin here.<br>
    <em>most HTML tags may be used</em>
  ]]></description>

    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.platform</depends>

    <!-- Extension points defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij">
        <projectService serviceImplementation="com.babs.crudwizardrygenerator.services.EntityGeneratorService"/>

    </extensions>
    <depends>com.intellij.modules.java</depends>

    
    <actions>
        <action id="com.babs.crudwizardrygenerator.actions.GenerateEntityAction"
                class="com.babs.crudwizardrygenerator.actions.GenerateEntityAction"
                text="Generate Entity"
                description="Generate a Lombok Entity class">
            <add-to-group group-id="NewGroup" anchor="last" />
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>

        <group id="CrudWizardry.GenerateGroup" text="Generate CRUD Components" popup="true">
            <add-to-group group-id="GenerateGroup" anchor="last"/>
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            
            <action id="com.babs.crudwizardrygenerator.actions.GenerateControllerAction"
                    class="com.babs.crudwizardrygenerator.actions.GenerateControllerAction"
                    text="Generate Controller"
                    description="Generates a Spring Boot Controller for this class"/>
            
            <action id="com.babs.crudwizardrygenerator.actions.GenerateServiceAction"
                    class="com.babs.crudwizardrygenerator.actions.GenerateServiceAction"
                    text="Generate Service"
                    description="Generates a Spring Boot Service for this class"/>
            
            <action id="com.babs.crudwizardrygenerator.actions.GenerateRepositoryAction"
                    class="com.babs.crudwizardrygenerator.actions.GenerateRepositoryAction"
                    text="Generate Repository"
                    description="Generates a Spring Data JPA Repository for this class"/>
            
            <action id="com.babs.crudwizardrygenerator.actions.GenerateDtoAction"
                    class="com.babs.crudwizardrygenerator.actions.GenerateDtoAction"
                    text="Generate DTO"
                    description="Generates a DTO for this class"/>
        </group>

    </actions>

</idea-plugin>
<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- Unique identifier of the plugin. It should be FQN. It cannot be changed between the plugin versions. -->
    <id>com.babs.crudwizardrygenerator</id>

    <!-- Public plugin name should be written in Title Case.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-name -->
    <name>SpringForge</name>

    <!-- A displayed Vendor name or Organization ID displayed on the Plugins Page. -->
    <vendor url="https://www.babscrontekker.com">BabsCron</vendor>

    <!-- Description of the plugin displayed on the Plugin Page and IDE Plugin Manager.
         Guidelines: https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-description -->
    <description><![CDATA[
    <h3>Accelerate Your Spring Boot Development</h3>
    <p>SpringForge is an IntelliJ IDEA plugin designed to automate the creation of boilerplate code for Spring Boot applications.</p>
    
    <p><b>Key Features:</b></p>
    <ul>
        <li><b>Entity Generation:</b> Quickly create JPA Entity classes with Lombok annotations.</li>
        <li><b>Repository Generation:</b> Generate Spring Data JPA Repositories for your entities.</li>
        <li><b>Service Layer:</b> Create Service interfaces and implementations with standard CRUD logic.</li>
        <li><b>Controller Generation:</b> Automatically build REST Controllers with standard endpoints.</li>
        <li><b>DTO Support:</b> Easily generate Data Transfer Objects (DTOs) from your entity classes.</li>
    </ul>

    <p>Stop writing repetitive boilerplate code and start focusing on what matters—your business logic!</p>
  ]]></description>

    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.platform</depends>

    <!-- Extension points defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij">
        <projectService serviceImplementation="com.babs.crudwizardrygenerator.services.EntityGeneratorService"/>

    </extensions>
    <depends>com.intellij.modules.java</depends>

    
    <actions>
        <action id="com.babs.crudwizardrygenerator.actions.GenerateEntityAction"
                class="com.babs.crudwizardrygenerator.actions.GenerateEntityAction"
                text="Generate CRUD"
                icon="AllIcons.Actions.IntentionBulb"
                description="Generate CRUD Components for the selected class or directory">
            <add-to-group group-id="NewGroup" anchor="last" />
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>

        <group id="CrudWizardry.GenerateGroup" text="Generate CRUD Components" popup="true" icon="AllIcons.Actions.IntentionBulb">
            <add-to-group group-id="GenerateGroup" anchor="last"/>
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            
            <action id="com.babs.crudwizardrygenerator.actions.GenerateControllerAction"
                    class="com.babs.crudwizardrygenerator.actions.GenerateControllerAction"
                    text="Generate Controller"
                    icon="AllIcons.Nodes.AbstractClass"
                    description="Generates a Spring Boot Controller for this class"/>
            
            <action id="com.babs.crudwizardrygenerator.actions.GenerateServiceAction"
                    class="com.babs.crudwizardrygenerator.actions.GenerateServiceAction"
                    text="Generate Service"
                    icon="AllIcons.Nodes.Interface"
                    description="Generates a Spring Boot Service for this class"/>
            
            <action id="com.babs.crudwizardrygenerator.actions.GenerateRepositoryAction"
                    class="com.babs.crudwizardrygenerator.actions.GenerateRepositoryAction"
                    text="Generate Repository"
                    icon="AllIcons.Nodes.DataColumn"
                    description="Generates a Spring Data JPA Repository for this class"/>
            
            <action id="com.babs.crudwizardrygenerator.actions.GenerateDtoAction"
                    class="com.babs.crudwizardrygenerator.actions.GenerateDtoAction"
                    text="Generate DTO"
                    icon="AllIcons.Nodes.Artifact"
                    description="Generates a DTO for this class"/>
        </group>

    </actions>

</idea-plugin>